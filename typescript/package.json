{
  "name": "openocr",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for the OpenOCR API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "keywords": ["ocr", "pdf", "document", "extraction"],
  "author": "OpenOCR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mothercoremasterchief-prog/openocr-client.git",
    "directory": "typescript"
  },
  "homepage": "https://open-ocr.com/docs/sdks",
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
